---
import Base from '../layouts/Base.astro';
import ProjectsSection from '../components/sections/ProjectsSection.astro';
import PublicationsSection from '../components/sections/PublicationsSection.astro';
import CVSection from '../components/sections/CVSection.astro';
import BeyondAcademicsSection from '../components/sections/BeyondAcademicsSection.astro';
import ContactSection from '../components/sections/ContactSection.astro';
---

<Base title="Md Shihab Sarker — Researcher & Developer" currentPage="/" enableScrollSpy={true}>
  <section id="home" class="scroll-section">
    <section class="hero animate">
      <div class="hero-layout">
        <div class="hero-header">
          <div class="hero-copy">
            <span class="page-label">Welcome</span>
            <h1>Md Shihab Sarker</h1>
            <p class="hero-role">BSc CSE Student · Data Science · Machine Learning</p>
          </div>
          <img src="/images/profile.jpeg" alt="Md Shihab Sarker portrait" class="hero-image" loading="lazy" />
        </div>

        <div class="hero-body">
          <p class="lead">
            I am a Computer Science student at BRAC University with a dual focus on Full-Stack Development and AI Research. I am an expert in the MERN architecture, building scalable software solutions from the ground up. My academic heart lies in Data Science and Deep Learning, where I research model efficiency and predictive patterns. I thrive at the intersection of robust software engineering and high-impact Artificial Intelligence.
          </p>

          <div class="cta-row">
            <a href="#cv" class="btn btn-primary hero-cta-btn">View CV</a>
            <a href="#projects" class="btn btn-outline hero-cta-btn">Projects</a>
            <a href="#contact" class="btn btn-outline hero-cta-btn">Get in touch</a>
          </div>
        </div>
      </div>
    </section>

    <hr class="divider" />

    <section class="quick-stats animate delay-2">
      <div class="stat-grid">
        <div class="stat">
          <span class="stat-num">_</span>
          <span class="stat-label">Repositories</span>
        </div>
        <div class="stat">
          <span class="stat-num">_</span>
          <span class="stat-label">Projects</span>
        </div>
        <div class="stat">
          <span class="stat-num">_</span>
          <span class="stat-label">Started BSc CSE</span>
        </div>
      </div>
    </section>

    <section class="recent animate delay-3">
      <h2>Recent Work</h2>
      <p>A selection of recent projects.</p>

      <div class="preview-list">
        <a href="https://github.com/Shihabsarker93/mern-project01" class="preview-item" target="_blank" rel="noopener">
          <div>
            <span class="mono">2025 · Full Stack</span>
            <h3>MERN Full-Stack House Rental Website</h3>
            <p>MongoDB, Express.js, React, and Node.js platform for buying, selling, and listing properties.</p>
          </div>
          <span class="arrow">→</span>
        </a>
        <a href="https://github.com/Shihabsarker93/hotel-booking" class="preview-item" target="_blank" rel="noopener">
          <div>
            <span class="mono">2024 · Web App</span>
            <h3>PHP-Based Hotel Booking System</h3>
            <p>PHP and MySQL booking system with reservation flow and secure user management.</p>
          </div>
          <span class="arrow">→</span>
        </a>
      </div>
    </section>
  </section>

  <section id="projects" class="scroll-section">
    <ProjectsSection />
  </section>

  <section id="publications" class="scroll-section">
    <PublicationsSection />
  </section>

  <section id="cv" class="scroll-section">
    <CVSection />
  </section>

  <section id="beyond-academics" class="scroll-section">
    <BeyondAcademicsSection />
  </section>

  <section id="contact" class="scroll-section">
    <ContactSection />
  </section>
</Base>

<style>
.scroll-section {
  scroll-margin-top: calc(var(--nav-h) + 0.5rem);
  padding-top: 0;
  margin-bottom: 3rem;
}

.scroll-section + .scroll-section {
  border-top: 1px solid var(--border);
  margin-top: 2.4rem;
  padding-top: 0;
}

.hero {
  margin-bottom: 0;
}

.hero-layout {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.hero-header {
  display: grid;
  grid-template-columns: 1.2fr 0.8fr;
  gap: 1.5rem;
  align-items: start;
}

.hero-copy {
  align-self: flex-start;
  padding-top: clamp(0.25rem, 1vh, 0.75rem);
}

.hero-role {
  font-family: var(--font-mono);
  font-size: 0.82rem;
  color: var(--text-subtle);
  letter-spacing: 0.04em;
  margin-top: 0.5rem;
  margin-bottom: 0;
}

.hero-image {
  width: 100%;
  max-width: 320px;
  border-radius: 12px;
  object-fit: cover;
  justify-self: end;
  margin-top: 1.5rem;
}

.hero-body {
  width: 100%;
  margin-top: 3.5rem;
}

.lead {
  font-size: 1.1rem;
  color: var(--text);
  font-weight: 300;
  line-height: 1.75;
  margin-top: 0;
}

.cta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  margin-top: 2rem;
}

.hero-cta-btn {
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.hero-cta-btn:hover {
  transform: translateY(-3px) scale(1.03);
  box-shadow: 0 6px 16px rgba(0, 0, 0, 0.08);
}

.stat-grid {
  display: flex;
  gap: 3rem;
}

.stat {
  display: flex;
  flex-direction: column;
}

.stat-num {
  font-family: var(--font-serif);
  font-size: 2.5rem;
  line-height: 1;
  color: var(--text);
}

.stat-label {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--text-subtle);
  margin-top: 0.25rem;
}

.recent h2 {
  margin-bottom: 0.5rem;
}

.preview-list {
  margin-top: 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 0;
}

.preview-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1.5rem 0;
  border-bottom: 1px solid var(--border);
  text-decoration: none;
  color: inherit;
  transition: padding-left 0.2s;
  gap: 1rem;
}

.preview-item:first-child {
  border-top: 1px solid var(--border);
}

.preview-item:hover {
  padding-left: 0.5rem;
}

.preview-item h3 {
  font-size: 1rem;
  margin: 0.2rem 0 0.3rem;
  color: var(--text);
}

.preview-item p {
  font-size: 0.88rem;
  margin: 0;
  color: var(--text-muted);
}

.preview-item .mono {
  display: block;
}

.arrow {
  font-size: 1.2rem;
  color: var(--text-subtle);
  flex-shrink: 0;
  transition: color 0.2s, transform 0.2s;
}

.preview-item:hover .arrow {
  color: var(--accent);
  transform: translateX(4px);
}

@media (max-width: 900px) {
  .hero-header {
    grid-template-columns: 1fr;
  }

  .hero-image {
    justify-self: start;
    margin-top: 1.5rem;
  }
}

@media (max-width: 720px) {
  .stat-grid {
    flex-direction: column;
    gap: 1.2rem;
  }
}
</style>
