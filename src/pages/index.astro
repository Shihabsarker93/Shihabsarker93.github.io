---
import Base from '../layouts/Base.astro';

const projFiles = await Astro.glob('../content/projects/*.md');
const projects = projFiles
  .map((f) => ({ ...f.frontmatter }))
  .sort((a, b) => (b.year || 0) - (a.year || 0));
const featured = projects.filter((p) => p.featured);
const others = projects.filter((p) => !p.featured);

const pubFiles = await Astro.glob('../content/publications/*.md');
const publications = pubFiles
  .map((f) => ({ ...f.frontmatter }))
  .sort((a, b) => (b.year || 0) - (a.year || 0));

const byYear = publications.reduce((acc, pub) => {
  acc[pub.year] = acc[pub.year] || [];
  acc[pub.year].push(pub);
  return acc;
}, {});

const years = Object.keys(byYear).sort((a, b) => Number(b) - Number(a));
