---
import Base from '../layouts/Base.astro';
---

<Base title="Contact — Md Shihab Sarker" currentPage="/contact">

  <div class="page-header animate">
    <span class="page-label">Get in touch</span>
    <h1>Contact</h1>
    <p>I'm always happy to connect for collaboration, projects, and opportunities.</p>
  </div>

  <div class="contact-grid animate delay-1">

    <!-- Primary email -->
    <div class="contact-block">
      <span class="contact-label">Email</span>
      <a href="mailto:shihabsarker650@gmail.com" class="contact-value">
        shihabsarker650@gmail.com
      </a>
      <p class="contact-note">Best for collaboration and general contact.</p>
    </div>

    <hr class="divider" />

    <!-- Links -->
    <div class="contact-block animate delay-2">
      <span class="contact-label">Profiles</span>
      <div class="profile-list">
        <a href="https://github.com/Shihabsarker93" class="profile-item" target="_blank" rel="noopener">
          <span class="profile-icon">⌨</span>
          <div>
            <span class="profile-name">GitHub</span>
            <span class="profile-handle">github.com/Shihabsarker93</span>
          </div>
          <span class="profile-arrow">→</span>
        </a>

        <a href="tel:+8801793473098" class="profile-item">
          <span class="profile-icon">☎</span>
          <div>
            <span class="profile-name">Phone</span>
            <span class="profile-handle">+8801793473098</span>
          </div>
          <span class="profile-arrow">→</span>
        </a>

        <a href="https://linkedin.com/in/md-shihab-sarker" class="profile-item" target="_blank" rel="noopener">
          <span class="profile-icon">◈</span>
          <div>
            <span class="profile-name">LinkedIn</span>
            <span class="profile-handle">linkedin.com/in/md-shihab-sarker</span>
          </div>
          <span class="profile-arrow">→</span>
        </a>
      </div>
    </div>

    <hr class="divider" />

    <!-- Office -->
    <div class="contact-block animate delay-3">
      <span class="contact-label">Location</span>
      <p class="contact-value-text">Dhaka, Bangladesh</p>
    </div>

  </div>

</Base>

<style>
.contact-grid { max-width: 560px; }

.contact-block { margin-bottom: 0; }

.contact-label {
  display: block;
  font-family: var(--font-mono);
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--text-subtle);
  margin-bottom: 0.75rem;
}

.contact-value {
  font-family: var(--font-serif);
  font-size: 1.4rem;
  color: var(--text);
  text-decoration: none;
  display: block;
  margin-bottom: 0.75rem;
  transition: color 0.2s;
}

.contact-value:hover { color: var(--accent); }

.contact-note {
  font-size: 0.85rem;
  color: var(--text-subtle);
  margin: 0;
}

.contact-value-text {
  font-size: 0.9rem;
  color: var(--text-muted);
  line-height: 1.8;
  margin: 0;
}

.profile-list { display: flex; flex-direction: column; }

.profile-item {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 0.9rem 0;
  border-bottom: 1px solid var(--border);
  text-decoration: none;
  color: inherit;
  transition: padding-left 0.2s;
}

.profile-item:first-child { border-top: 1px solid var(--border); }
.profile-item:hover { padding-left: 0.4rem; }

.profile-icon {
  font-size: 1rem;
  color: var(--text-subtle);
  width: 1.5rem;
  text-align: center;
  flex-shrink: 0;
}

.profile-item > div {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.profile-name {
  font-size: 0.9rem;
  font-weight: 400;
  color: var(--text);
}

.profile-handle {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  color: var(--text-subtle);
}

.profile-arrow {
  color: var(--text-subtle);
  transition: color 0.2s, transform 0.2s;
}

.profile-item:hover .profile-arrow {
  color: var(--accent);
  transform: translateX(4px);
}
</style>
