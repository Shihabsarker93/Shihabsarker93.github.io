---
import Base from '../../layouts/Base.astro';
---

<Base title="Recent Trips — Md Shihab Sarker" currentPage="/Beyond_Academics/trips">
  <div class="page-header animate">
    <span class="page-label">Tours & Travel</span>
    <h1>Recent Trips</h1>
    <p>A photo space for my journeys outside academics.</p>
  </div>

  <section class="section animate delay-1">
    <div class="gallery">
      <figure class="trip-photo card">
        <img src="/tour/images1/image1.jpg" alt="Trip photo 1" loading="lazy" />
        <figcaption>Trip memory 1</figcaption>
      </figure>
      <figure class="trip-photo card">
        <img src="/tour/images1/6118438676074270440.jpg" alt="Trip photo 2" loading="lazy" />
        <figcaption>Trip memory 2</figcaption>
      </figure>
      <figure class="trip-photo card">
        <img src="/tour/images1/image2" alt="Trip photo 3" loading="lazy" />
        <figcaption>Trip memory 3</figcaption>
      </figure>
    </div>
  </section>

  <div class="actions animate delay-2">
    <a href="/#beyond-academics" class="btn btn-outline">Back to Beyond Academics</a>
  </div>
</Base>

<style>
.section { margin-bottom: 2rem; }

.gallery {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 1rem;
}

.trip-photo {
  padding: 0.75rem;
}

.trip-photo img {
  width: 100%;
  height: auto;
  border-radius: 6px;
  display: block;
}

.trip-photo figcaption {
  margin-top: 0.6rem;
  font-size: 0.8rem;
  color: var(--text-subtle);
  font-family: var(--font-mono);
}

.actions {
  margin-top: 0.5rem;
}
</style>
