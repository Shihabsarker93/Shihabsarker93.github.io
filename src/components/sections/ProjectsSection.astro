---
const projFiles = await Astro.glob('../../content/projects/*.md');

const projects = projFiles
  .map((f) => ({ ...f.frontmatter }))
  .sort((a, b) => (b.year || 0) - (a.year || 0));

const featured = projects.filter((p) => p.featured);
const others = projects.filter((p) => !p.featured);
---

<div class="page-header animate">
  <span class="page-label">Work</span>
  <h1>Projects</h1>
  <p>Open-source tools, research prototypes, and personal builds.</p>
</div>

{featured.length > 0 && (
  <section class="section animate delay-1">
    <h2 class="section-title">Featured</h2>
    <div class="grid grid-2">
      {featured.map((project) => (
        <article class="card project-card">
          <div class="card-top">
            {project.status && <span class={`status-badge ${project.status}`}>{project.status}</span>}
            <span class="mono">{project.year}</span>
          </div>
          <h3>{project.title}</h3>
          <p>{project.description}</p>
          {project.tags && (
            <div class="tags">
              {project.tags.map((tag) => <span class="tag">{tag}</span>)}
            </div>
          )}
          <div class="card-links">
            {project.github && (
              <a href={project.github} class="btn btn-outline" target="_blank" rel="noopener">GitHub</a>
            )}
            {project.demo && (
              <a href={project.demo} class="btn btn-primary" target="_blank" rel="noopener">Live Demo</a>
            )}
            {project.paper && (
              <a href={project.paper} class="btn btn-outline" target="_blank" rel="noopener">Paper</a>
            )}
          </div>
        </article>
      ))}
    </div>
  </section>
)}

{others.length > 0 && (
  <section class="section animate delay-2">
    {featured.length > 0 && <h2 class="section-title">Other Projects</h2>}
    <div class="other-list">
      {others.map((project) => (
        <article class="other-item">
          <div class="other-main">
            <h3>
              {project.title}
              {project.status && <span class={`status-badge small ${project.status}`}>{project.status}</span>}
            </h3>
            <p>{project.description}</p>
            {project.tags && (
              <div class="tags">
                {project.tags.map((tag) => <span class="tag">{tag}</span>)}
              </div>
            )}
          </div>
          <div class="other-links">
            <span class="mono">{project.year}</span>
            {project.github && (
              <a href={project.github} class="btn btn-outline" target="_blank" rel="noopener">GitHub</a>
            )}
            {project.demo && (
              <a href={project.demo} class="btn btn-outline" target="_blank" rel="noopener">Demo</a>
            )}
          </div>
        </article>
      ))}
    </div>
  </section>
)}

{projects.length === 0 && (
  <p class="empty">No projects yet. Add <code>.md</code> files to <code>src/content/projects/</code>.</p>
)}

<style>
.section {
  margin-bottom: 3rem;
}

.section-title {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--text-subtle);
  margin-bottom: 1.25rem;
}

.project-card {
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
}

.project-card h3 {
  margin: 0;
  font-size: 1.05rem;
}

.project-card p {
  font-size: 0.88rem;
  margin: 0;
  flex: 1;
}

.card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 0.25rem;
}

.card-links {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-top: 0.5rem;
}

.status-badge {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  padding: 0.15rem 0.5rem;
  border-radius: 2px;
}

.status-badge.active {
  background: #e8f5e8;
  color: #2d7a2d;
}

.status-badge.archived {
  background: #f5f0e8;
  color: #7a5c2d;
}

.status-badge.wip {
  background: #e8f0f5;
  color: #2d5c7a;
}

.status-badge.small {
  margin-left: 0.5rem;
}

.other-list {
  display: flex;
  flex-direction: column;
}

.other-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 1.5rem;
  padding: 1.25rem 0;
  border-bottom: 1px solid var(--border);
}

.other-item:first-child {
  border-top: 1px solid var(--border);
}

.other-main {
  flex: 1;
}

.other-main h3 {
  font-size: 0.98rem;
  margin-bottom: 0.3rem;
}

.other-main p {
  font-size: 0.85rem;
  margin: 0;
}

.other-links {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  flex-shrink: 0;
}

.empty {
  color: var(--text-subtle);
  font-family: var(--font-mono);
  font-size: 0.85rem;
  padding: 2rem 0;
}

@media (max-width: 720px) {
  .other-item {
    flex-direction: column;
    gap: 0.75rem;
  }
}
</style>
