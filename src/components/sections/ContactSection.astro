<div class="page-header animate">
  <span class="page-label">Get in touch</span>
  <h1>Contact</h1>
  <p>I'm always happy to connect for collaboration, projects, and opportunities.</p>
</div>

<div class="contact-grid animate delay-1">
  <form id="contact-mail-form" class="contact-form-card contact-card" novalidate>
    <div class="field">
      <label for="contact-email">Your email</label>
      <input id="contact-email" name="email" type="email" placeholder="jacob@google.com" required />
    </div>

    <div class="field">
      <label for="contact-subject">Subject</label>
      <input id="contact-subject" name="subject" type="text" placeholder="Just saying hi" required />
    </div>

    <div class="field">
      <label for="contact-message">Message</label>
      <textarea id="contact-message" name="message" rows="5" placeholder="Let's talk about..." required></textarea>
    </div>

    <button type="submit" class="contact-send-btn">Send Message</button>
    <p id="contact-form-status" class="contact-form-status" aria-live="polite"></p>
    <p class="contact-form-note">
      This opens your default email app to send the message to
      <a href="mailto:shihabsarker650@gmail.com">shihabsarker650@gmail.com</a>.
    </p>
  </form>

  <div class="contact-side contact-card animate delay-2">
    <div class="contact-block">
      <span class="contact-label">Email</span>
      <a href="mailto:shihabsarker650@gmail.com" class="contact-value">shihabsarker650@gmail.com</a>
      <p class="contact-note">Best for collaboration and general contact.</p>
    </div>

    <div class="contact-block">
      <span class="contact-label">Profiles</span>
      <div class="profile-list">
        <a href="https://github.com/Shihabsarker93" class="profile-item" target="_blank" rel="noopener">
          <span class="profile-icon">⌨</span>
          <div>
            <span class="profile-name">GitHub</span>
            <span class="profile-handle">github.com/Shihabsarker93</span>
          </div>
          <span class="profile-arrow">→</span>
        </a>

        <a href="tel:+8801793473098" class="profile-item">
          <span class="profile-icon">☎</span>
          <div>
            <span class="profile-name">Phone</span>
            <span class="profile-handle">+8801793473098</span>
          </div>
          <span class="profile-arrow">→</span>
        </a>

        <a href="https://www.linkedin.com/in/md-shihab-sarker-26065a249/" class="profile-item" target="_blank" rel="noopener">
          <span class="profile-icon">◈</span>
          <div>
            <span class="profile-name">LinkedIn</span>
            <span class="profile-handle">linkedin.com/in/md-shihab-sarker-26065a249</span>
          </div>
          <span class="profile-arrow">→</span>
        </a>
      </div>
    </div>

    <div class="contact-block animate delay-3">
      <span class="contact-label">Location</span>
      <p class="contact-value-text">Dhaka, Bangladesh</p>
    </div>
  </div>
</div>

<script>
  const contactForm = document.getElementById('contact-mail-form');
  const formStatus = document.getElementById('contact-form-status');

  if (contactForm) {
    contactForm.addEventListener('submit', (event) => {
      event.preventDefault();

      const formData = new FormData(contactForm);
      const email = `${formData.get('email') || ''}`.trim();
      const subject = `${formData.get('subject') || ''}`.trim();
      const message = `${formData.get('message') || ''}`.trim();

      if (!email || !subject || !message) {
        if (formStatus) formStatus.textContent = 'Please fill all fields before sending.';
        return;
      }

      const mailSubject = `[Portfolio Contact] ${subject}`;
      const mailBody = `From: ${email}\n\n${message}`;
      const mailtoUrl =
        `mailto:shihabsarker650@gmail.com?subject=${encodeURIComponent(mailSubject)}&body=${encodeURIComponent(mailBody)}`;

      if (formStatus) formStatus.textContent = 'Opening your email app...';
      window.location.href = mailtoUrl;
    });
  }
</script>
