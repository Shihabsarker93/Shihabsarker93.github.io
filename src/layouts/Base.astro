---
import '../styles/global.css';

const { title = 'Md Shihab Sarker — Portfolio', description = 'Academic & developer portfolio', currentPage = '' } = Astro.props;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/projects', label: 'Projects' },
  { href: '/publications', label: 'Publications' },
  { href: '/cv', label: 'CV' },
  { href: '/Beyond_Academics', label: 'Beyond_Academics' },
  { href: '/contact', label: 'Contact' },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <nav>
    <div class="nav-inner">
      <a href="/" class="nav-logo">Md Shihab Sarker</a>
      <ul class="nav-links">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class={
                currentPage === link.href ||
                (link.href !== '/' && currentPage.startsWith(`${link.href}/`))
                  ? 'active'
                  : ''
              }
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>

  <main>
    <slot />
  </main>

  <footer>
    <p>© {new Date().getFullYear()} Md Shihab Sarker · Built with Astro · Hosted on GitHub Pages</p>
  </footer>
</body>
</html>
